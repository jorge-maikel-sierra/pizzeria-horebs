#. Plugin Name of the plugin
msgid "Enable Abilities for MCP"
msgstr "Habilitar Abilities para MCP"

#. Description of the plugin
msgid "Manage which WordPress Abilities are exposed to MCP servers. Enable or disable each ability individually from the dashboard."
msgstr "Gestiona qué Abilities de WordPress se exponen a los servidores MCP. Habilita o deshabilita cada ability individualmente desde el escritorio."

#. Author of the plugin
msgid "Fabio Montenegro"
msgstr "Fabio Montenegro"

#. Section labels and descriptions (enable-abilities-for-mcp.php)
msgid "WordPress Core"
msgstr "Core de WordPress"

msgid "Native WordPress core abilities. Exposed to MCP with the public flag."
msgstr "Abilities nativas del core de WordPress. Se exponen al MCP con el flag público."

msgid "Site Information"
msgstr "Información del sitio"

msgid "General site data: name, URL, description, language, timezone, WP version."
msgstr "Datos generales del sitio: nombre, URL, descripción, idioma, zona horaria, versión de WP."

msgid "User Information"
msgstr "Información del usuario"

msgid "Current user data: name, email, role, avatar."
msgstr "Datos del usuario actual: nombre, email, rol, avatar."

msgid "Environment Information"
msgstr "Información del entorno"

msgid "Technical details: PHP version, DB server, environment type."
msgstr "Detalles técnicos: versión de PHP, servidor de BD, tipo de entorno."

msgid "Read (Query Only)"
msgstr "Lectura (solo consultas)"

msgid "Only query data, do not modify anything. Safest to expose via MCP."
msgstr "Solo consultan datos, no modifican nada. Las más seguras para exponer vía MCP."

msgid "Get Posts"
msgstr "Obtener entradas"

msgid "List posts with filters by status, category, count, and order."
msgstr "Lista entradas con filtros por estado, categoría, cantidad y orden."

msgid "Get Single Post"
msgstr "Obtener entrada individual"

msgid "Full post detail by ID, including content, meta data, and featured image."
msgstr "Detalle completo de una entrada por ID, incluyendo contenido, metadatos e imagen destacada."

msgid "Get Categories"
msgstr "Obtener categorías"

msgid "List all categories with ID, name, slug, and post count."
msgstr "Lista todas las categorías con ID, nombre, slug y cantidad de entradas."

msgid "Get Tags"
msgstr "Obtener etiquetas"

msgid "List all tags with ID, name, slug, and post count."
msgstr "Lista todas las etiquetas con ID, nombre, slug y cantidad de entradas."

msgid "Get Pages"
msgstr "Obtener páginas"

msgid "List site pages with title, status, and hierarchy."
msgstr "Lista las páginas del sitio con título, estado y jerarquía."

msgid "Get Comments"
msgstr "Obtener comentarios"

msgid "List comments with filters by status, post, and count."
msgstr "Lista comentarios con filtros por estado, entrada y cantidad."

msgid "Get Media"
msgstr "Obtener medios"

msgid "List media library files with filters by type."
msgstr "Lista archivos de la biblioteca de medios con filtros por tipo."

msgid "Get Users"
msgstr "Obtener usuarios"

msgid "List site users with ID, name, email, and role."
msgstr "Lista usuarios del sitio con ID, nombre, email y rol."

msgid "Write (Create & Modify)"
msgstr "Escritura (crear y modificar)"

msgid "Create or modify content. Require appropriate MCP user permissions."
msgstr "Crean o modifican contenido. Requieren permisos de usuario MCP adecuados."

msgid "Create Post"
msgstr "Crear entrada"

msgid "Create a new post with title, content, categories, tags, featured image, and more."
msgstr "Crea una nueva entrada con título, contenido, categorías, etiquetas, imagen destacada y más."

msgid "Update Post"
msgstr "Actualizar entrada"

msgid "Modify an existing post. Only updates the fields provided."
msgstr "Modifica una entrada existente. Solo actualiza los campos proporcionados."

msgid "Delete Post"
msgstr "Eliminar entrada"

msgid "Send a post to trash or permanently delete it."
msgstr "Envía una entrada a la papelera o la elimina permanentemente."

msgid "Create Category"
msgstr "Crear categoría"

msgid "Create a new category with name, slug, description, and parent."
msgstr "Crea una nueva categoría con nombre, slug, descripción y categoría padre."

msgid "Create Tag"
msgstr "Crear etiqueta"

msgid "Create a new tag with name, slug, and description."
msgstr "Crea una nueva etiqueta con nombre, slug y descripción."

msgid "Create Page"
msgstr "Crear página"

msgid "Create a new page with title, content, status, and parent page."
msgstr "Crea una nueva página con título, contenido, estado y página padre."

msgid "Moderate Comment"
msgstr "Moderar comentario"

msgid "Change comment status: approve, hold, spam, or trash."
msgstr "Cambia el estado de un comentario: aprobar, retener, spam o papelera."

msgid "Reply to Comment"
msgstr "Responder comentario"

msgid "Reply to an existing comment as the authenticated user."
msgstr "Responde a un comentario existente como el usuario autenticado."

msgid "Upload Image from URL"
msgstr "Subir imagen desde URL"

msgid "Download an image from an external URL and register it in the media library. Returns the attachment ID."
msgstr "Descarga una imagen desde una URL externa y la registra en la biblioteca de medios. Devuelve el ID del adjunto."

msgid "SEO — Rank Math"
msgstr "SEO — Rank Math"

msgid "Query and update Rank Math SEO metadata on posts and pages."
msgstr "Consulta y actualiza metadatos SEO de Rank Math en entradas y páginas."

msgid "Get Rank Math Metadata"
msgstr "Obtener metadatos de Rank Math"

msgid "Get Rank Math SEO metadata for a post or page: title, description, keywords, robots, Open Graph, and more."
msgstr "Obtiene metadatos SEO de Rank Math para una entrada o página: título, descripción, palabras clave, robots, Open Graph y más."

msgid "Update Rank Math SEO / Focus Keyword"
msgstr "Actualizar SEO / Palabra clave de Rank Math"

msgid "Update focus keyword, SEO title, description, canonical URL, robots, and Open Graph via Rank Math."
msgstr "Actualiza la palabra clave principal, título SEO, descripción, URL canónica, robots y Open Graph a través de Rank Math."

msgid "Utility"
msgstr "Utilidades"

msgid "Auxiliary tools that complement the workflow."
msgstr "Herramientas auxiliares que complementan el flujo de trabajo."

msgid "Search and Replace"
msgstr "Buscar y reemplazar"

msgid "Search for text in a post content and replace it with another."
msgstr "Busca texto en el contenido de una entrada y lo reemplaza por otro."

msgid "Site Statistics"
msgstr "Estadísticas del sitio"

msgid "Site summary: total posts, pages, categories, tags, comments, and users."
msgstr "Resumen del sitio: total de entradas, páginas, categorías, etiquetas, comentarios y usuarios."

msgid "Custom Post Types"
msgstr "Tipos de contenido personalizado"

msgid "Discover and manage Custom Post Types registered by plugins or themes. Excludes posts, pages, and attachments which have dedicated abilities."
msgstr "Descubre y gestiona tipos de contenido personalizado registrados por plugins o temas. Excluye entradas, páginas y adjuntos que tienen abilities dedicadas."

msgid "List Post Types"
msgstr "Listar tipos de contenido"

msgid "List all public Custom Post Types with their labels, taxonomies, supported features, and capabilities."
msgstr "Lista todos los tipos de contenido personalizado públicos con sus etiquetas, taxonomías, características soportadas y capacidades."

msgid "Get CPT Items"
msgstr "Obtener elementos de CPT"

msgid "List items from any CPT with filters by status, count, order, and search."
msgstr "Lista elementos de cualquier CPT con filtros por estado, cantidad, orden y búsqueda."

msgid "Get Single CPT Item"
msgstr "Obtener elemento individual de CPT"

msgid "Get full detail of a CPT item by ID, including content, meta data, taxonomies, and featured image."
msgstr "Obtiene el detalle completo de un elemento de CPT por ID, incluyendo contenido, metadatos, taxonomías e imagen destacada."

msgid "Create CPT Item"
msgstr "Crear elemento de CPT"

msgid "Create a new item in any CPT with title, content, status, taxonomies, and featured image."
msgstr "Crea un nuevo elemento en cualquier CPT con título, contenido, estado, taxonomías e imagen destacada."

msgid "Update CPT Item"
msgstr "Actualizar elemento de CPT"

msgid "Update an existing CPT item. Only modifies the fields provided."
msgstr "Actualiza un elemento de CPT existente. Solo modifica los campos proporcionados."

msgid "Delete CPT Item"
msgstr "Eliminar elemento de CPT"

msgid "Send a CPT item to trash or permanently delete it."
msgstr "Envía un elemento de CPT a la papelera o lo elimina permanentemente."

msgid "Get CPT Taxonomies"
msgstr "Obtener taxonomías de CPT"

msgid "List taxonomies and their terms for a given CPT."
msgstr "Lista las taxonomías y sus términos para un CPT dado."

msgid "Assign Terms to CPT Item"
msgstr "Asignar términos a elemento de CPT"

msgid "Assign taxonomy terms to a CPT item. Can add to or replace existing terms."
msgstr "Asigna términos de taxonomía a un elemento de CPT. Puede añadir o reemplazar los términos existentes."

#. Section notices (enable-abilities-for-mcp.php)
msgid "No Custom Post Types detected on this site. These abilities will become available when a plugin or theme registers custom post types (e.g., WooCommerce, ACF, JetEngine)."
msgstr "No se detectaron tipos de contenido personalizado en este sitio. Estas abilities estarán disponibles cuando un plugin o tema registre tipos de contenido personalizado (por ejemplo, WooCommerce, ACF, JetEngine)."

msgid "Rank Math SEO plugin is not active. These abilities require Rank Math to function."
msgstr "El plugin Rank Math SEO no está activo. Estas abilities requieren Rank Math para funcionar."

#. Admin page strings (includes/admin.php)
msgid "WP Abilities"
msgstr "WP Abilities"

msgid "Enable Abilities for MCP requires the MCP Adapter plugin to work. %1$sDownload MCP Adapter%2$s"
msgstr "Enable Abilities for MCP requiere el plugin MCP Adapter para funcionar. %1$sDescargar MCP Adapter%2$s"

msgid "Ability keys updated to English for internationalization. Your settings have been preserved."
msgstr "Las claves de abilities se han actualizado a inglés para internacionalización. Tu configuración se ha conservado."

msgid "API Key active"
msgstr "Clave API activa"

msgid "Regenerate API Key"
msgstr "Regenerar clave API"

msgid "Revoke API Key"
msgstr "Revocar clave API"

msgid "This will invalidate the previous key. Continue?"
msgstr "Esto invalidará la clave anterior. ¿Continuar?"

msgid "Are you sure you want to revoke the API Key? External connections will stop working."
msgstr "¿Estás seguro de que quieres revocar la clave API? Las conexiones externas dejarán de funcionar."

msgid "Copied!"
msgstr "¡Copiado!"

msgid "Copy"
msgstr "Copiar"

msgid "Settings saved successfully."
msgstr "Configuración guardada correctamente."

msgid "You do not have sufficient permissions."
msgstr "No tienes permisos suficientes."

msgid "API Key generated successfully."
msgstr "Clave API generada correctamente."

msgid "API Key revoked successfully."
msgstr "Clave API revocada correctamente."

msgid "Manage which WordPress abilities are available for MCP. Enable or disable each one according to your needs."
msgstr "Gestiona qué abilities de WordPress están disponibles para MCP. Habilita o deshabilita cada una según tus necesidades."

msgid "API Key for MCP"
msgstr "Clave API para MCP"

msgid "Generate an API Key to authenticate external connections to the MCP server via Bearer token."
msgstr "Genera una clave API para autenticar conexiones externas al servidor MCP mediante token Bearer."

msgid "API Key active — generated on %s"
msgstr "Clave API activa — generada el %s"

msgid "No API Key configured."
msgstr "No hay clave API configurada."

msgid "Copy this key now. It will not be shown again:"
msgstr "Copia esta clave ahora. No se mostrará de nuevo:"

msgid "Generate API Key"
msgstr "Generar clave API"

msgid "Use this key in the authentication header: %s"
msgstr "Usa esta clave en el encabezado de autenticación: %s"

msgid "Your site MCP endpoint"
msgstr "Endpoint MCP de tu sitio"

msgid "Use this URL to connect your MCP client:"
msgstr "Usa esta URL para conectar tu cliente MCP:"

msgid "Claude Desktop configuration example"
msgstr "Ejemplo de configuración de Claude Desktop"

msgid "Add this to your configuration file %s:"
msgstr "Añade esto a tu archivo de configuración %s:"

msgid "Replace YOUR-API-KEY with the API Key generated above."
msgstr "Reemplaza YOUR-API-KEY con la clave API generada arriba."

msgid "abilities enabled"
msgstr "abilities habilitadas"

msgid "Enable All"
msgstr "Habilitar todas"

msgid "Disable All"
msgstr "Deshabilitar todas"

msgid "Caution"
msgstr "Precaución"

msgid "All"
msgstr "Todas"

msgid "Save Changes"
msgstr "Guardar cambios"

#. Ability registration strings (includes/abilities.php) — longer descriptions
msgid "Retrieves a list of blog posts with optional filters by status, category, count, and order."
msgstr "Obtiene una lista de entradas del blog con filtros opcionales por estado, categoría, cantidad y orden."

msgid "Retrieves all details of a specific post by ID, including full content, metadata, and featured image."
msgstr "Obtiene todos los detalles de una entrada específica por ID, incluyendo contenido completo, metadatos e imagen destacada."

msgid "Retrieves all blog categories with their ID, name, slug, description, and post count."
msgstr "Obtiene todas las categorías del blog con su ID, nombre, slug, descripción y cantidad de entradas."

msgid "Retrieves all blog tags with their ID, name, slug, and post count."
msgstr "Obtiene todas las etiquetas del blog con su ID, nombre, slug y cantidad de entradas."

msgid "Retrieves site pages with their title, status, content, and hierarchy (parent/child)."
msgstr "Obtiene las páginas del sitio con su título, estado, contenido y jerarquía (padre/hijo)."

msgid "Retrieves blog comments with optional filters by status, post, and count. Useful for moderation and analysis."
msgstr "Obtiene los comentarios del blog con filtros opcionales por estado, entrada y cantidad. Útil para moderación y análisis."

msgid "Retrieves media library files (images, videos, documents) with filters by MIME type and search."
msgstr "Obtiene archivos de la biblioteca de medios (imágenes, vídeos, documentos) con filtros por tipo MIME y búsqueda."

msgid "Retrieves the list of site users with their ID, name, email, and role. Useful for assigning post authors."
msgstr "Obtiene la lista de usuarios del sitio con su ID, nombre, email y rol. Útil para asignar autores a entradas."

msgid "Creates a new blog post. Accepts title, HTML content, excerpt, categories, tags, featured image, and status. Defaults to draft."
msgstr "Crea una nueva entrada de blog. Acepta título, contenido HTML, extracto, categorías, etiquetas, imagen destacada y estado. Por defecto queda como borrador."

msgid "Updates an existing post. Only the provided fields are modified, others remain unchanged."
msgstr "Actualiza una entrada existente. Solo se modifican los campos proporcionados, los demás permanecen sin cambios."

msgid "Sends a post to trash or permanently deletes it. Defaults to trash."
msgstr "Envía una entrada a la papelera o la elimina permanentemente. Por defecto va a la papelera."

msgid "Creates a new blog category with name, slug, description, and parent category (optional)."
msgstr "Crea una nueva categoría de blog con nombre, slug, descripción y categoría padre (opcional)."

msgid "Creates a new blog tag with name, slug, and description."
msgstr "Crea una nueva etiqueta de blog con nombre, slug y descripción."

msgid "Creates a new WordPress page with title, content, status, and parent page (for hierarchy)."
msgstr "Crea una nueva página de WordPress con título, contenido, estado y página padre (para jerarquía)."

msgid "Changes a comment status: approve, hold, mark as spam, or send to trash."
msgstr "Cambia el estado de un comentario: aprobar, retener, marcar como spam o enviar a la papelera."

msgid "Replies to an existing comment on a post or page. The reply is published as the current authenticated user."
msgstr "Responde a un comentario existente en una entrada o página. La respuesta se publica como el usuario autenticado actual."

msgid "Downloads an image from an external URL and registers it in the WordPress media library. Optionally assigns it as featured image for a post. Returns the attachment ID and local URL."
msgstr "Descarga una imagen desde una URL externa y la registra en la biblioteca de medios de WordPress. Opcionalmente la asigna como imagen destacada de una entrada. Devuelve el ID del adjunto y la URL local."

msgid "Retrieves all Rank Math SEO metadata for a post or page: title, description, keywords, robots, advanced robots, Open Graph, Twitter Card, schema, breadcrumb, cornerstone, and SEO score."
msgstr "Obtiene todos los metadatos SEO de Rank Math para una entrada o página: título, descripción, palabras clave, robots, robots avanzados, Open Graph, Twitter Card, schema, breadcrumb, cornerstone y puntuación SEO."

msgid "Updates Rank Math SEO metadata on a post or page (rank_math_focus_keyword, rank_math_title, rank_math_description, etc). Use this ability to set or change the focus keyword, SEO title, meta description, canonical URL, robots, Open Graph, Twitter Card, breadcrumb, schema snippet, cornerstone, and pillar content. Only the provided fields are modified."
msgstr "Actualiza los metadatos SEO de Rank Math en una entrada o página (rank_math_focus_keyword, rank_math_title, rank_math_description, etc). Usa esta ability para establecer o cambiar la palabra clave principal, título SEO, meta descripción, URL canónica, robots, Open Graph, Twitter Card, breadcrumb, schema snippet, cornerstone y contenido pilar. Solo se modifican los campos proporcionados."

msgid "Searches for text in a specific post content and replaces it with another. Useful for corrections and updates."
msgstr "Busca texto en el contenido de una entrada específica y lo reemplaza por otro. Útil para correcciones y actualizaciones."

msgid "Returns a summary with the total posts, pages, categories, tags, comments, and users of the site."
msgstr "Devuelve un resumen con el total de entradas, páginas, categorías, etiquetas, comentarios y usuarios del sitio."

msgid "Lists all custom post types registered on the site, with their configuration, supported features, and associated taxonomies."
msgstr "Lista todos los tipos de contenido personalizado registrados en el sitio, con su configuración, características soportadas y taxonomías asociadas."

msgid "No custom post types detected on this site."
msgstr "No se detectaron tipos de contenido personalizado en este sitio."

msgid "Retrieves a list of items from a specific custom post type with filtering, search, and taxonomy query support."
msgstr "Obtiene una lista de elementos de un tipo de contenido personalizado específico con soporte para filtros, búsqueda y consultas por taxonomía."

msgid "The custom post type slug (e.g. product, portfolio)."
msgstr "El slug del tipo de contenido personalizado (ej. product, portfolio)."

msgid "Number of items to return (default 20, max 100)."
msgstr "Número de elementos a devolver (por defecto 20, máximo 100)."

msgid "Filter by status: publish, draft, pending, private, any (default publish)."
msgstr "Filtrar por estado: publish, draft, pending, private, any (por defecto publish)."

msgid "Order by: date, title, modified, menu_order, ID, rand (default date)."
msgstr "Ordenar por: date, title, modified, menu_order, ID, rand (por defecto date)."

msgid "Sort direction: ASC or DESC (default DESC)."
msgstr "Dirección de orden: ASC o DESC (por defecto DESC)."

msgid "Search keyword to filter items."
msgstr "Palabra clave de búsqueda para filtrar elementos."

msgid "Taxonomy query array. Each item: {taxonomy, terms, field (slug|id), operator (IN|NOT IN|AND)}."
msgstr "Array de consulta por taxonomía. Cada elemento: {taxonomy, terms, field (slug|id), operator (IN|NOT IN|AND)}."

msgid "Get CPT Item"
msgstr "Obtener elemento de CPT"

msgid "Retrieves full details of a single custom post type item, including all meta fields, taxonomies, and content."
msgstr "Obtiene el detalle completo de un elemento de tipo de contenido personalizado, incluyendo todos los campos meta, taxonomías y contenido."

msgid "The ID of the item to retrieve."
msgstr "El ID del elemento a obtener."

msgid "Item not found."
msgstr "Elemento no encontrado."

msgid "Creates a new item in a custom post type. Content is optional as some CPTs store data in custom fields instead."
msgstr "Crea un nuevo elemento en un tipo de contenido personalizado. El contenido es opcional ya que algunos CPT almacenan datos en campos personalizados."

msgid "The custom post type slug."
msgstr "El slug del tipo de contenido personalizado."

msgid "The item title."
msgstr "El título del elemento."

msgid "The item content (optional — some CPTs store data in meta fields instead)."
msgstr "El contenido del elemento (opcional — algunos CPT almacenan datos en campos meta)."

msgid "The item excerpt."
msgstr "El extracto del elemento."

msgid "Post status: draft, publish, pending, private (default draft)."
msgstr "Estado: draft, publish, pending, private (por defecto draft)."

msgid "Attachment ID for the featured image."
msgstr "ID de adjunto para la imagen destacada."

msgid "Parent item ID (for hierarchical CPTs)."
msgstr "ID del elemento padre (para CPT jerárquicos)."

msgid "Menu order value."
msgstr "Valor de orden del menú."

msgid "Author user ID."
msgstr "ID de usuario del autor."

msgid "The URL slug for the item."
msgstr "El slug de URL para el elemento."

msgid "Object mapping taxonomy slugs to arrays of term slugs or IDs. Example: {\"product_cat\": [\"clothing\"], \"product_tag\": [\"sale\"]}."
msgstr "Objeto que mapea slugs de taxonomía a arrays de slugs o IDs de términos. Ejemplo: {\"product_cat\": [\"clothing\"], \"product_tag\": [\"sale\"]}."

msgid "Object mapping meta keys to values. Supports plugin meta like _price, _sku, ACF fields, etc."
msgstr "Objeto que mapea claves meta a valores. Soporta meta de plugins como _price, _sku, campos de ACF, etc."

msgid "You do not have permission to create items of this type."
msgstr "No tienes permiso para crear elementos de este tipo."

#, php-format
msgid "%s created successfully."
msgstr "%s creado correctamente."

msgid "Updates an existing custom post type item. Only provided fields are modified (partial update)."
msgstr "Actualiza un elemento existente de tipo de contenido personalizado. Solo se modifican los campos proporcionados (actualización parcial)."

msgid "The ID of the item to update."
msgstr "El ID del elemento a actualizar."

msgid "New title."
msgstr "Nuevo título."

msgid "New content (optional — some CPTs use meta fields instead)."
msgstr "Nuevo contenido (opcional — algunos CPT usan campos meta)."

msgid "New excerpt."
msgstr "Nuevo extracto."

msgid "New status: draft, publish, pending, private."
msgstr "Nuevo estado: draft, publish, pending, private."

msgid "Attachment ID for the featured image. Pass 0 to remove."
msgstr "ID de adjunto para la imagen destacada. Pasa 0 para eliminar."

msgid "New URL slug."
msgstr "Nuevo slug de URL."

msgid "Object mapping taxonomy slugs to arrays of term slugs or IDs. Replaces existing terms."
msgstr "Objeto que mapea slugs de taxonomía a arrays de slugs o IDs de términos. Reemplaza los términos existentes."

msgid "You do not have permission to edit this item."
msgstr "No tienes permiso para editar este elemento."

#, php-format
msgid "%s updated successfully."
msgstr "%s actualizado correctamente."

msgid "Deletes a custom post type item. By default moves to trash; use force_delete to permanently remove."
msgstr "Elimina un elemento de tipo de contenido personalizado. Por defecto lo mueve a la papelera; usa force_delete para eliminar permanentemente."

msgid "The ID of the item to delete."
msgstr "El ID del elemento a eliminar."

msgid "If true, permanently deletes instead of trashing (default false)."
msgstr "Si es verdadero, elimina permanentemente en vez de enviar a la papelera (por defecto false)."

msgid "You do not have permission to delete this item."
msgstr "No tienes permiso para eliminar este elemento."

msgid "Failed to delete the item."
msgstr "Error al eliminar el elemento."

#, php-format
msgid "%s permanently deleted."
msgstr "%s eliminado permanentemente."

#, php-format
msgid "%s moved to trash."
msgstr "%s movido a la papelera."

msgid "Retrieves all taxonomies associated with a custom post type, including their terms."
msgstr "Obtiene todas las taxonomías asociadas a un tipo de contenido personalizado, incluyendo sus términos."

msgid "If true, only show terms with posts (default false)."
msgstr "Si es verdadero, solo muestra términos con entradas (por defecto false)."

msgid "Max number of terms per taxonomy (default 100, max 500)."
msgstr "Número máximo de términos por taxonomía (por defecto 100, máximo 500)."

msgid "Assigns taxonomy terms to a custom post type item. Can replace or append terms."
msgstr "Asigna términos de taxonomía a un elemento de tipo de contenido personalizado. Puede reemplazar o añadir términos."

msgid "The ID of the item to assign terms to."
msgstr "El ID del elemento al que asignar términos."

msgid "The taxonomy slug."
msgstr "El slug de la taxonomía."

msgid "Array of term slugs or IDs to assign."
msgstr "Array de slugs o IDs de términos a asignar."

msgid "If true, appends terms instead of replacing (default false)."
msgstr "Si es verdadero, añade términos en vez de reemplazar (por defecto false)."

msgid "The specified taxonomy does not exist."
msgstr "La taxonomía especificada no existe."

#, php-format
msgid "The taxonomy \"%1$s\" is not associated with the \"%2$s\" post type."
msgstr "La taxonomía \"%1$s\" no está asociada con el tipo de contenido \"%2$s\"."

msgid "You do not have permission to assign terms for this taxonomy."
msgstr "No tienes permiso para asignar términos en esta taxonomía."

#, php-format
msgid "%1$d term(s) assigned for %2$s."
msgstr "%1$d término(s) asignado(s) para %2$s."

#. Validation error strings (includes/abilities.php)
msgid "This content type has dedicated abilities. Use the specific abilities for posts, pages, or media instead."
msgstr "Este tipo de contenido tiene abilities dedicadas. Usa las abilities específicas para entradas, páginas o medios."

msgid "The specified content type does not exist."
msgstr "El tipo de contenido especificado no existe."

msgid "This content type is not publicly accessible."
msgstr "Este tipo de contenido no es accesible públicamente."

#. Ability category strings (includes/abilities.php)
msgid "Content Management"
msgstr "Gestión de contenido"

msgid "Abilities to create, read, update, and delete blog content."
msgstr "Abilities para crear, leer, actualizar y eliminar contenido del blog."

msgid "User Management"
msgstr "Gestión de usuarios"

msgid "Abilities to query site user information."
msgstr "Abilities para consultar información de usuarios del sitio."

msgid "Abilities to get general information and site statistics."
msgstr "Abilities para obtener información general y estadísticas del sitio."

msgid "Abilities to discover and manage custom post types registered by plugins or themes."
msgstr "Abilities para descubrir y gestionar tipos de contenido personalizado registrados por plugins o temas."
